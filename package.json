{
  "name": "withings-cli",
  "version": "0.1.1",
  "description": "Thin local-first CLI for the Withings Public API.",
  "keywords": [
    "bun",
    "cli",
    "health",
    "oauth2",
    "withings"
  ],
  "homepage": "https://github.com/Hiro5409/withings-cli#readme",
  "bugs": {
    "url": "https://github.com/Hiro5409/withings-cli/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hiro5409/withings-cli.git"
  },
  "bin": {
    "withings": "bin/withings"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun run build:cli && bun run build:lib",
    "build:cli": "bun build src/main.ts --compile --outfile withings",
    "build:lib": "rm -rf dist && bun build src/index.ts --outfile dist/index.js --target browser && tsgo -p tsconfig.dist.json",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "lint": "oxlint && oxfmt --check",
    "format": "oxfmt",
    "knip": "knip",
    "publint": "publint run --pack bun",
    "attw": "attw --pack --profile esm-only .",
    "check:package": "bun run build:lib && bun run publint && bun run attw",
    "audit": "bun audit",
    "secrets": "gitleaks git --no-banner --redact .",
    "prepare": "bun run build:lib",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run knip && bun test && bun run check:package"
  },
  "dependencies": {
    "gunshi": "^0.32.0",
    "yoctocolors": "^2.1.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260610.1",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "publint": "^0.3.21"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
